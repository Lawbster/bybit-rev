{
  "name": "reverse-copy",
  "version": "1.0.0",
  "description": "Reverse copy-trade analysis and strategy detection",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:vps": "rm -rf dist && tsc -p tsconfig.vps.json",
    "dev": "ts-node src/index.ts",
    "verify": "ts-node src/verify-pairs.ts",
    "analyze": "ts-node src/analyze.ts",
    "monitor": "ts-node src/monitor.ts",
    "detect": "ts-node src/strategy-detect.ts",
    "fetch": "ts-node src/fetch-candles.ts",
    "sim": "ts-node src/sim-trader.ts",
    "sim:all": "ts-node src/sim-trader.ts SIRENUSDT 5000 PIPPINUSDT",
    "collect": "ts-node src/data-collector.ts",
    "hl-collect": "ts-node src/hyperliquid-collector.ts",
    "backtest:old": "ts-node src/backtest.ts",
    "backtest": "ts-node src/backtest-v2.ts",
    "backtest:ws": "ts-node src/backtest-ws.ts",
    "bot": "ts-node src/bot/index.ts",
    "bot:init": "ts-node src/bot/index.ts --init",
    "discord-alarms": "ts-node src/discord-alarms.ts",
    "commander": "ts-node src/discord-commander.ts",
    "pf0-short": "ts-node src/bot/pf0-short.ts",
    "sui-ladder": "ts-node src/bot/sui-ladder.ts",
    "fart-ladder": "ts-node src/bot/sui-ladder.ts --config=fart-ladder-config.json",
    "check": "ts-node src/price-check.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bybit-api": "^4.6.1",
    "dotenv": "^17.3.1",
    "simple-statistics": "^7.8.9",
    "technicalindicators": "^3.1.0",
    "ws": "^7.5.10",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
